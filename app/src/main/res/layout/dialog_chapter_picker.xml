<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_tv_dialog_shell"
    android:elevation="24dp"
    android:orientation="vertical"
    android:paddingStart="28dp"
    android:paddingTop="26dp"
    android:paddingEnd="28dp"
    android:paddingBottom="26dp">

    <TextView
        style="@style/MpvTv.TextSmallCaps"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/chapter_button"
        android:textColor="?attr/mpvAccentHot" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:singleLine="true"
            android:text="@string/dialog_title_chapter"
            android:textColor="@color/tv_text"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/chapterCountText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="18dp"
            android:background="@drawable/bg_glass_panel"
            android:fontFamily="monospace"
            android:paddingStart="12dp"
            android:paddingTop="7dp"
            android:paddingEnd="12dp"
            android:paddingBottom="7dp"
            android:textColor="@color/tv_text_dim"
            android:textSize="12sp"
            android:textStyle="bold"
            tools:text="#03 / 12" />
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="20dp"
        android:layout_weight="1"
        android:background="@drawable/bg_tv_panel_card"
        android:clipChildren="true"
        android:clipToOutline="true"
        tools:targetApi="s">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/list"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginEnd="14dp"
            android:clipToPadding="true"
            android:overScrollMode="never"
            android:paddingStart="12dp"
            android:paddingTop="12dp"
            android:paddingEnd="8dp"
            android:paddingBottom="12dp"
            android:scrollbars="none"
            app:layoutManager="LinearLayoutManager"
            tools:listitem="@layout/dialog_chapter_item" />

        <View
            android:id="@+id/chapterScrollbarThumb"
            android:layout_width="3dp"
            android:layout_height="48dp"
            android:layout_gravity="end|top"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="8dp"
            android:layout_marginBottom="12dp"
            android:alpha="0"
            android:background="@drawable/bg_tv_scrollbar_thumb"
            android:focusable="false"
            android:importantForAccessibility="no"
            android:visibility="invisible" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:gravity="end"
        android:orientation="horizontal">

        <Button
            android:id="@+id/cancelBtn"
            style="@style/Mpv.SurfaceButton.Compact"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:minWidth="84dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:text="@string/dialog_cancel" />
    </LinearLayout>
</LinearLayout>
