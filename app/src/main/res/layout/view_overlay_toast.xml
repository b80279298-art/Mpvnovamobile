<?xml version="1.0" encoding="utf-8"?>
<!-- Same visual structure as the in-player toast, hosted inside open dialogs. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_player_toast"
    android:elevation="24dp"
    android:gravity="center"
    android:orientation="vertical"
    android:paddingStart="18dp"
    android:paddingTop="12dp"
    android:paddingEnd="18dp"
    android:paddingBottom="12dp">

    <TextView
        android:id="@+id/overlayToastTitle"
        style="@style/MpvTv.TextSmallCaps"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="?attr/mpvAccentHot"
        android:visibility="gone"
        tools:text="Preset"
        tools:visibility="visible" />

    <TextView
        android:id="@+id/overlayToastMessage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:gravity="center"
        android:maxWidth="420dp"
        android:textColor="@color/tv_text"
        android:textSize="16sp"
        android:textStyle="bold"
        tools:text="Crunchyroll" />
</LinearLayout>
