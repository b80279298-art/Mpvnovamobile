<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_tv_dialog_shell"
    android:elevation="24dp"
    android:orientation="vertical"
    android:paddingStart="22dp"
    android:paddingTop="20dp"
    android:paddingEnd="22dp"
    android:paddingBottom="18dp">

    <TextView
        style="@style/MpvTv.TextSmallCaps"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/sub_style_title"
        android:textColor="?attr/mpvAccentHot" />

    <TextView
        android:id="@+id/presetDialogTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:ellipsize="end"
        android:letterSpacing="0"
        android:singleLine="true"
        android:textColor="@color/tv_text"
        android:textSize="24sp"
        android:textStyle="bold"
        tools:text="Save preset" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="14dp"
        android:layout_weight="1"
        android:background="@drawable/bg_tv_panel_card"
        android:clipChildren="true"
        android:clipToOutline="true"
        tools:targetApi="s">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:paddingStart="12dp"
            android:paddingTop="12dp"
            android:paddingEnd="12dp"
            android:paddingBottom="12dp">

            <EditText
                android:id="@+id/presetNameInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/sub_style_preset_name_hint"
                android:importantForAutofill="no"
                android:inputType="textCapSentences"
                android:maxLength="12"
                android:maxLines="1"
                android:singleLine="true"
                android:textColor="@color/tv_text"
                android:textColorHint="@color/tv_text_dim"
                android:textSize="16sp"
                tools:ignore="LabelFor" />

            <TextView
                android:id="@+id/presetNameCount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:gravity="end"
                android:textColor="@color/tv_text_dim"
                android:textSize="11sp"
                tools:text="0/12" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="8dp"
                android:background="@color/tv_stroke" />

            <ScrollView
                android:id="@+id/presetScroll"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="10dp"
                android:layout_weight="1"
                android:clipToPadding="false"
                android:fillViewport="false"
                android:paddingEnd="10dp"
                android:scrollbarDefaultDelayBeforeFade="1200"
                android:scrollbarFadeDuration="240"
                android:scrollbarSize="3dp"
                android:scrollbarStyle="insideInset"
                android:scrollbarThumbVertical="@drawable/bg_tv_scrollbar_thumb"
                android:scrollbarTrackVertical="@drawable/bg_tv_scrollbar_track"
                android:scrollbars="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingEnd="10dp">

                <LinearLayout
                    android:id="@+id/presetIncludeLayoutRow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_tv_track_row"
                    android:clickable="true"
                    android:focusable="true"
                    android:minHeight="54dp"
                    android:orientation="horizontal"
                    android:paddingStart="10dp"
                    android:paddingTop="7dp"
                    android:paddingEnd="10dp"
                    android:paddingBottom="7dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_vertical"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/sub_style_preset_include_layout"
                            android:textColor="@color/tv_text"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="@string/sub_style_preset_include_layout_summary"
                            android:textColor="@color/tv_text_dim"
                            android:textSize="10sp" />
                    </LinearLayout>

                    <ImageView
                        android:id="@+id/presetIncludeLayoutCheck"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:layout_gravity="center_vertical"
                        android:layout_marginStart="12dp"
                        android:contentDescription="@string/sub_style_preset_include_layout"
                        android:src="@drawable/ic_tv_check"
                        android:visibility="invisible"
                        app:tint="@color/tv_text"
                        tools:visibility="visible" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/presetSubScaleRow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_tv_track_row"
                    android:minHeight="54dp"
                    android:orientation="horizontal"
                    android:paddingStart="10dp"
                    android:paddingTop="7dp"
                    android:paddingEnd="10dp"
                    android:paddingBottom="7dp">

                    <FrameLayout
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:layout_gravity="center_vertical"
                        android:background="@drawable/bg_tv_icon_chip">

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_style_size"
                            app:tint="@color/tv_text" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_vertical"
                        android:layout_marginStart="10dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/btn_sub_scale"
                            android:textColor="@color/tv_text"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:ellipsize="end"
                            android:maxLines="2"
                            android:text="@string/btn_sub_scale_summary"
                            android:textColor="@color/tv_text_dim"
                            android:textSize="10sp" />
                    </LinearLayout>

                    <ImageButton
                        android:id="@+id/presetSubScaleMinusBtn"
                        style="@style/MpvPlayer.ButtonBarIconButton"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:layout_gravity="center_vertical"
                        android:contentDescription="@string/btn_decrease"
                        android:minWidth="30dp"
                        android:minHeight="30dp"
                        app:srcCompat="@drawable/ic_remove_24dp"
                        app:tint="@color/tv_text" />

                    <TextView
                        android:id="@+id/presetSubScaleValue"
                        android:layout_width="58dp"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_vertical"
                        android:gravity="center"
                        android:textColor="@color/tv_text"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        tools:text="1.05x" />

                    <ImageButton
                        android:id="@+id/presetSubScalePlusBtn"
                        style="@style/MpvPlayer.ButtonBarIconButton"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:layout_gravity="center_vertical"
                        android:contentDescription="@string/btn_increase"
                        android:minWidth="30dp"
                        android:minHeight="30dp"
                        app:srcCompat="@drawable/ic_add_24dp"
                        app:tint="@color/tv_text" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/presetSubPosRow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_tv_track_row"
                    android:minHeight="54dp"
                    android:orientation="horizontal"
                    android:paddingStart="10dp"
                    android:paddingTop="7dp"
                    android:paddingEnd="10dp"
                    android:paddingBottom="7dp">

                    <FrameLayout
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:layout_gravity="center_vertical"
                        android:background="@drawable/bg_tv_icon_chip">

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_sub_position"
                            app:tint="@color/tv_text" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_vertical"
                        android:layout_marginStart="10dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/btn_sub_pos"
                            android:textColor="@color/tv_text"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:ellipsize="end"
                            android:maxLines="2"
                            android:text="@string/btn_sub_pos_summary"
                            android:textColor="@color/tv_text_dim"
                            android:textSize="10sp" />
                    </LinearLayout>

                    <ImageButton
                        android:id="@+id/presetSubPosMinusBtn"
                        style="@style/MpvPlayer.ButtonBarIconButton"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:layout_gravity="center_vertical"
                        android:contentDescription="@string/btn_decrease"
                        android:minWidth="30dp"
                        android:minHeight="30dp"
                        app:srcCompat="@drawable/ic_remove_24dp"
                        app:tint="@color/tv_text" />

                    <TextView
                        android:id="@+id/presetSubPosValue"
                        android:layout_width="58dp"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_vertical"
                        android:gravity="center"
                        android:textColor="@color/tv_text"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        tools:text="94%" />

                    <ImageButton
                        android:id="@+id/presetSubPosPlusBtn"
                        style="@style/MpvPlayer.ButtonBarIconButton"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:layout_gravity="center_vertical"
                        android:contentDescription="@string/btn_increase"
                        android:minWidth="30dp"
                        android:minHeight="30dp"
                        app:srcCompat="@drawable/ic_add_24dp"
                        app:tint="@color/tv_text" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/presetOverrideAssRow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_tv_track_row"
                    android:clickable="true"
                    android:focusable="true"
                    android:minHeight="54dp"
                    android:orientation="horizontal"
                    android:paddingStart="10dp"
                    android:paddingTop="7dp"
                    android:paddingEnd="10dp"
                    android:paddingBottom="7dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_vertical"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/sub_style_override_ass"
                            android:textColor="@color/tv_text"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="@string/sub_style_override_ass_summary"
                            android:textColor="@color/tv_text_dim"
                            android:textSize="10sp" />
                    </LinearLayout>

                    <ImageView
                        android:id="@+id/presetOverrideAssCheck"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:layout_gravity="center_vertical"
                        android:layout_marginStart="12dp"
                        android:contentDescription="@string/sub_style_override_ass"
                        android:src="@drawable/ic_tv_check"
                        android:visibility="invisible"
                        app:tint="@color/tv_text"
                        tools:visibility="visible" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/presetForceAllRow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_tv_track_row"
                    android:clickable="true"
                    android:focusable="true"
                    android:minHeight="54dp"
                    android:orientation="horizontal"
                    android:paddingStart="10dp"
                    android:paddingTop="7dp"
                    android:paddingEnd="10dp"
                    android:paddingBottom="7dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_vertical"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/sub_style_force_all_ass"
                            android:textColor="@color/tv_text"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="@string/sub_style_force_all_ass_summary"
                            android:textColor="@color/tv_text_dim"
                            android:textSize="10sp" />
                    </LinearLayout>

                    <ImageView
                        android:id="@+id/presetForceAllCheck"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:layout_gravity="center_vertical"
                        android:layout_marginStart="12dp"
                        android:contentDescription="@string/sub_style_force_all_ass"
                        android:src="@drawable/ic_tv_check"
                        android:visibility="invisible"
                        app:tint="@color/tv_text"
                        tools:visibility="visible" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/presetSelectiveRow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_tv_track_row"
                    android:clickable="true"
                    android:focusable="true"
                    android:minHeight="54dp"
                    android:orientation="horizontal"
                    android:paddingStart="10dp"
                    android:paddingTop="7dp"
                    android:paddingEnd="10dp"
                    android:paddingBottom="7dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_vertical"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/sub_style_selective_ass"
                            android:textColor="@color/tv_text"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="@string/sub_style_selective_ass_summary"
                            android:textColor="@color/tv_text_dim"
                            android:textSize="10sp" />
                    </LinearLayout>

                    <ImageView
                        android:id="@+id/presetSelectiveCheck"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:layout_gravity="center_vertical"
                        android:layout_marginStart="12dp"
                        android:contentDescription="@string/sub_style_selective_ass"
                        android:src="@drawable/ic_tv_check"
                        android:visibility="invisible"
                        app:tint="@color/tv_text"
                        tools:visibility="visible" />
                </LinearLayout>
            </LinearLayout>
            </ScrollView>
        </LinearLayout>
    </FrameLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="end"
        android:orientation="horizontal">

        <Button
            android:id="@+id/presetCancelBtn"
            style="@style/Mpv.SurfaceButton.Compact"
            android:layout_width="wrap_content"
            android:layout_height="42dp"
            android:minWidth="76dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:text="@string/dialog_cancel" />

        <Button
            android:id="@+id/presetSaveBtn"
            style="@style/Mpv.SurfaceButton"
            android:layout_width="wrap_content"
            android:layout_height="42dp"
            android:layout_marginStart="10dp"
            android:minWidth="76dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:text="@string/dialog_save" />
    </LinearLayout>
</LinearLayout>
