<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_tv_dialog_shell"
    android:elevation="24dp"
    android:orientation="vertical"
    android:paddingStart="28dp"
    android:paddingTop="26dp"
    android:paddingEnd="28dp"
    android:paddingBottom="22dp">

    <TextView
        style="@style/MpvTv.TextSmallCaps"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/video_adjustment" />

    <TextView
        android:id="@+id/adjustmentTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:ellipsize="end"
        android:letterSpacing="0"
        android:singleLine="true"
        android:textColor="@color/tv_text"
        android:textSize="28sp"
        android:textStyle="bold"
        tools:text="Video brightness" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:background="@drawable/bg_tv_panel_card"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingTop="18dp"
        android:paddingEnd="16dp"
        android:paddingBottom="18dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/adjustmentValue"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="monospace"
                android:textColor="@color/tv_text"
                android:textSize="22sp"
                android:textStyle="bold"
                tools:text="100%" />

            <Button
                android:id="@+id/resetBtn"
                style="@style/Mpv.SurfaceButton.Compact"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:minWidth="84dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:text="@string/dialog_reset" />
        </LinearLayout>

        <SeekBar
            android:id="@+id/adjustmentSeekBar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:focusable="true"
            android:focusableInTouchMode="false"
            android:maxHeight="8dp"
            android:minHeight="8dp"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:progressDrawable="@drawable/seekbar_progress_tv"
            android:splitTrack="false"
            android:thumb="@drawable/seekbar_thumb_tv"
            android:thumbOffset="16dp" />

        <LinearLayout
            android:id="@+id/rememberRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_tv_track_row"
            android:clickable="true"
            android:focusable="true"
            android:minHeight="64dp"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingTop="10dp"
            android:paddingEnd="12dp"
            android:paddingBottom="10dp"
            android:visibility="gone"
            tools:visibility="visible">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/remember_video_adjustment"
                    android:textColor="@color/tv_text"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="@string/remember_video_adjustment_summary"
                    android:textColor="@color/tv_text_dim"
                    android:textSize="11sp" />
            </LinearLayout>

            <ImageView
                android:id="@+id/rememberCheck"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center_vertical"
                android:layout_marginStart="12dp"
                android:contentDescription="@string/remember_video_adjustment"
                android:src="@drawable/ic_tv_check"
                android:visibility="invisible"
                app:tint="@color/tv_text"
                tools:visibility="visible" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:gravity="end"
        android:orientation="horizontal">

        <Button
            android:id="@+id/cancelBtn"
            style="@style/Mpv.SurfaceButton.Compact"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:minWidth="84dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:text="@string/dialog_cancel" />

        <Button
            android:id="@+id/okBtn"
            style="@style/Mpv.SurfaceButton"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_marginStart="10dp"
            android:minWidth="84dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:text="@string/dialog_ok" />
    </LinearLayout>
</LinearLayout>
