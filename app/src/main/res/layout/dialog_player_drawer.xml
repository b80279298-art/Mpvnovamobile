<?xml version="1.0" encoding="utf-8"?>
<!-- Player settings drawer. Sits flush against the right edge of the screen
     (we set gravity=END on the dialog window) with a translucent panel
     background. Right column is the tab list, left column is a RecyclerView
     so scroll range and scrollbar behavior match the other player dialogs. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_tv_dialog_shell"
    android:elevation="24dp"
    android:orientation="horizontal">

    <LinearLayout
        android:id="@+id/drawerContentFrame"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="14dp"
        android:layout_marginBottom="16dp"
        android:layout_weight="2.7"
        android:orientation="vertical"
        tools:ignore="NestedWeights">

        <include
            android:id="@+id/drawerStaticHeader"
            layout="@layout/drawer_row_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginEnd="20dp"
            android:paddingStart="8dp"
            android:paddingTop="12dp"
            android:paddingEnd="6dp"
            tools:ignore="RtlSymmetry" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="2dp"
            android:layout_weight="1"
            android:background="@drawable/bg_tv_panel_card"
            android:clipToOutline="true"
            android:paddingStart="8dp"
            android:paddingTop="8dp"
            android:paddingBottom="4dp"
            tools:targetApi="s">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/drawerContentList"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginEnd="20dp"
                android:clipToPadding="false"
                android:descendantFocusability="afterDescendants"
                android:focusable="true"
                android:nextFocusRight="@id/tabBtnVideo"
                android:overScrollMode="never"
                android:paddingStart="20.5dp"
                android:paddingTop="12dp"
                android:paddingEnd="9.5dp"
                android:paddingBottom="20dp"
                android:scrollbars="none"
                app:layoutManager="LinearLayoutManager"
                tools:ignore="RtlSymmetry"
                tools:listitem="@layout/drawer_row_full_button" />

            <View
                android:id="@+id/drawerContentScrollbarThumb"
                android:layout_width="3dp"
                android:layout_height="48dp"
                android:layout_gravity="end|top"
                android:layout_marginTop="10dp"
                android:layout_marginEnd="8dp"
                android:layout_marginBottom="12dp"
                android:alpha="0"
                android:background="@drawable/bg_tv_scrollbar_thumb"
                android:focusable="false"
                android:importantForAccessibility="no"
                android:visibility="invisible" />
        </FrameLayout>
    </LinearLayout>

    <View
        android:id="@+id/drawerDivider"
        android:layout_width="1dp"
        android:layout_height="match_parent"
        android:alpha="0.18"
        android:background="@color/tv_text_dim" />

    <LinearLayout
        android:id="@+id/drawerTabColumn"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1.1"
        android:orientation="vertical"
        android:paddingStart="14dp"
        android:paddingTop="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            android:paddingStart="6dp"
            android:text="@string/action_settings"
            android:textColor="@color/tv_text"
            android:textSize="22sp"
            android:textStyle="bold"
            tools:ignore="RtlSymmetry" />

        <Button
            android:id="@+id/tabBtnVideo"
            style="@style/Mpv.DrawerTabButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nextFocusLeft="@id/drawerContentList"
            android:text="@string/drawer_tab_video" />

        <Button
            android:id="@+id/tabBtnAudio"
            style="@style/Mpv.DrawerTabButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:nextFocusLeft="@id/drawerContentList"
            android:text="@string/drawer_tab_audio" />

        <Button
            android:id="@+id/tabBtnSubtitles"
            style="@style/Mpv.DrawerTabButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:nextFocusLeft="@id/drawerContentList"
            android:text="@string/drawer_tab_subtitles" />

        <Button
            android:id="@+id/tabBtnPlayback"
            style="@style/Mpv.DrawerTabButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:nextFocusLeft="@id/drawerContentList"
            android:text="@string/drawer_tab_playback" />

        <Button
            android:id="@+id/tabBtnInterface"
            style="@style/Mpv.DrawerTabButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:nextFocusLeft="@id/drawerContentList"
            android:text="@string/drawer_tab_interface" />
    </LinearLayout>
</LinearLayout>
