<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_tv_dialog_shell"
    android:elevation="24dp"
    android:orientation="vertical"
    android:paddingStart="28dp"
    android:paddingTop="26dp"
    android:paddingEnd="28dp"
    android:paddingBottom="26dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                style="@style/MpvTv.TextSmallCaps"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/action_playlist" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/action_playlist"
                android:textColor="@color/tv_text"
                android:textSize="24sp"
                android:textStyle="bold" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/repeatBtn"
            style="@style/MpvPlayer.ButtonBarIconButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:contentDescription="@string/action_repeat"
            android:focusable="true"
            android:nextFocusRight="@id/shuffleBtn"
            android:src="@drawable/ic_repeat_24dp"
            app:tint="@color/tv_text" />

        <ImageButton
            android:id="@+id/shuffleBtn"
            style="@style/MpvPlayer.ButtonBarIconButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:contentDescription="@string/action_shuffle"
            android:focusable="true"
            android:nextFocusLeft="@id/repeatBtn"
            android:src="@drawable/ic_shuffle_24dp"
            app:tint="@color/tv_text" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_tv_panel_card"
        android:clipToPadding="false"
        android:padding="12dp"
        android:scrollbarDefaultDelayBeforeFade="1200"
        android:scrollbarFadeDuration="240"
        android:scrollbarSize="3dp"
        android:scrollbarStyle="insideInset"
        android:scrollbarThumbVertical="@drawable/bg_tv_scrollbar_thumb"
        android:scrollbarTrackVertical="@drawable/bg_tv_scrollbar_track"
        android:scrollbars="vertical"
        app:layoutManager="LinearLayoutManager"
        tools:listitem="@layout/dialog_playlist_item" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/fileBtn"
            style="@style/Mpv.SurfaceButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:text="@string/action_pick_file" />

        <Button
            android:id="@+id/urlBtn"
            style="@style/Mpv.SurfaceButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:text="@string/action_open_url" />

    </LinearLayout>

</LinearLayout>
