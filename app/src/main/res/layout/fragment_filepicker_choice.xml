<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_margin="24dp"
        android:background="@drawable/bg_hero_panel"
        android:orientation="vertical"
        android:padding="24dp"
        tools:ignore="UselessParent">

        <TextView
            style="@style/MpvTv.TextSmallCaps"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/file_picker_title" />

        <TextView
            android:id="@android:id/message"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:textColor="@color/tv_text"
            android:textSize="26sp"
            android:textStyle="bold"
            tools:text="Pick a source" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/file_picker_choice_subtitle"
            android:textColor="@color/tv_text_dim"
            android:textSize="14sp" />

        <Button
            android:id="@+id/fileBtn"
            style="@style/Mpv.SurfaceButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/action_pick_file_old" />

        <Button
            android:id="@+id/urlBtn"
            style="@style/Mpv.SurfaceButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/action_open_url" />

        <Button
            android:id="@+id/docBtn"
            style="@style/Mpv.SurfaceButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/action_open_doc" />
    </LinearLayout>
</FrameLayout>
