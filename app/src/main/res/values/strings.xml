    <string name="pref_default_audio_language_title">Default audio language</string>
    <string name="pref_default_audio_language_message">Audio language(s) to be selected by default when playing a video with multiple audio streams.\nTwo- or three-letter languages codes work. Multiple values can be delimited by comma.</string>

    <string name="pref_default_subtitle_language_title">Default subtitle language</string>
    <string name="pref_default_subtitle_language_message">Subtitle language(s) to be selected by default when playing a video with multiple subtitles.\nTwo- or three-letter languages codes work. Multiple values can be delimited by comma.</string>

    <string name="pref_hardware_decoding_title">Hardware decoding</string>
    <string name="pref_hardware_decoding_summary">Attempt hardware decoding before falling back to software. This is generally more efficient.</string>
    <string name="pref_decoder_auto_fallback_title">Automatic decoder fallback</string>
    <string name="pref_decoder_auto_fallback_summary">Let mpvNova temporarily override your preferred decoder for known trouble cases.</string>
    <string name="pref_shield_decoder_mode_title">Shield decoder mode</string>
    <string name="pref_shield_decoder_mode_summary">Use a Shield-specific fallback for Hi10P H.264. Turn off to keep the normal decoder modes only.</string>
    <string name="pref_shield_decoder_fallback_title">Shield Hi10P fallback</string>
    <string name="pref_shield_decoder_fallback_summary">All options software-decode Hi10P H.264 — no hardware can decode it — they differ only in how far the tuning goes.</string>
    <string name="shield_fallback_default_title">G-NEXT SW — no tuning</string>
    <string name="shield_fallback_default_desc">Strictly stock playback: software decode through the standard G-NEXT path with no extra tweaks.</string>
    <string name="shield_fallback_light_title">G-NEXT SW — light tuning</string>
    <string name="shield_fallback_light_desc">Skips the deblocking filter on non reference frames (big CPU saving, minor quality cost), uses a 1 second audio buffer, and upscales with Lanczos sharp. Not always recommended. Some Hi10P streams get major AV sync or framedrop issues with this. If that happens, switch back to no tuning and/or restart your Shield.</string>
    <string name="shield_fallback_framedrop_title">G-NEXT SW frame drop tuning</string>
    <string name="shield_fallback_framedrop_desc">Light tuning plus frame dropping: when the Shield\'s audio clock slips and video starts drifting out of sync, the player drops late frames to stay in sync instead of drifting until you reboot. Use this if audio and video desync over time. Not always recommended. Some Hi10P streams get major AV sync or framedrop issues with this. If that happens, switch back to no tuning and/or restart your Shield.</string>
    <string name="pref_autopause_controls_overlay_title">Pause when controls show</string>
    <string name="pref_autopause_controls_overlay_summary">Automatically pause playback while the controls overlay is visible, so navigating doesn\'t fight the decoder for CPU. Applies to every file.</string>
    <string name="pref_autopause_shield_hi10p_title">Pause Hi10P on Shield</string>
    <string name="pref_autopause_shield_hi10p_summary">On Shield devices, automatically pause playback while the controls overlay is visible during Hi10P H.264 files (where the SW decoder is too tight to share CPU with the UI). Independent of the general option above — turn off if you\'d rather accept some A/V drift to keep video running.</string>
    <string name="pref_preferred_decoder_mode_title">Preferred decoder mode</string>
    <string name="pref_preferred_decoder_mode_summary">Choose the decoder mode to use by default when automatic decoder fallback is off.</string>

    <string name="pref_background_play_title">Background playback</string>
    <string name="pref_background_play_summary">Decide when playback should be automatically resumed background.</string>
    <string name="pref_background_play_default" translatable="false">never</string>

    <string name="pref_save_position_title">Save position on quit</string>
    <string name="pref_save_position_summary">Remember current playback position on exit. When the same file is played again, the player will seek to the previous position.</string>

    <string name="pref_new_intent_replace_title">Play new files immediately</string>
    <string name="pref_new_intent_replace_summary">When opening new files while the player is in background, replace the current playlist instead of adding at end.</string>

