    <string name="pref_bottom_controls_title">Show controls at bottom of screen</string>
    <string name="pref_bottom_controls_summary">When on, the player controls dock to the bottom of the screen. When off, they float as a centered overlay above the bottom edge.</string>
    <string name="pref_ui_scale_title">UI scale</string>
    <string name="pref_ui_scale_summary">Size of the on-screen interface. Lower is smaller, higher is bigger. Applies on every device regardless of its display density.</string>
