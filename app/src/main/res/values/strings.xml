    <string name="pref_player_controls_timeout_default" translatable="false">5000</string>
    <string name="pref_keep_controls_visible_paused_title">Keep controls visible while paused</string>
    <string name="pref_keep_controls_visible_paused_summary">When playback is paused, keep the player controls on screen until playback resumes or you hide them manually.</string>
