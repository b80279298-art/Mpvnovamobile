<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Shared dark palette used across player, home, file picker, and settings. -->

    <!-- Accent colors -->
    <color name="tv_purple">#FFD6D6D6</color>
    <color name="tv_purple_hot">#FFFFFFFF</color>
    <color name="tv_purple_deep">#FF9A9A9A</color>
    <color name="tv_purple_ink">#FF202020</color>

    <!-- Surfaces -->
    <color name="tv_charcoal">#FF0A0B0D</color>
    <color name="tv_surface">#B30E1115</color>
    <color name="tv_surface_alt">#7A111419</color>
    <color name="tv_surface_soft">#12FFFFFF</color>
    <color name="tv_surface_strong">#B0111418</color>

    <!-- Text -->
    <color name="tv_text">#FFF7F7F7</color>
    <color name="tv_text_dim">#FFBCBCBC</color>
    <color name="tv_text_mute">#FF858585</color>
    <color name="tv_text_on_accent">#FF111418</color>
    <color name="tv_filter_active_icon">#FFC08CFF</color>

    <!-- Borders and focus -->
