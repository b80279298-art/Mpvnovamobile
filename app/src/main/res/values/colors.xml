    <color name="tv_stroke_focus">#FFF1F1F1</color>
    <color name="tv_focus_wash">#26FFFFFF</color>
    <color name="tv_focus_wash_soft">#14FFFFFF</color>

    <!-- Legacy aliases -->
    <item name="accent" type="color">@color/tv_purple_hot</item>

    <color name="tint_normal">@color/tv_text</color>
    <color name="tint_disabled">#FF47505D</color>
