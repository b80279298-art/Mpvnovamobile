<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="270"
                android:startColor="?attr/mpvHeroStart"
                android:endColor="?attr/mpvHeroEnd" />
            <stroke android:width="1dp" android:color="?attr/mpvStroke" />
            <corners android:radius="32dp" />
        </shape>
    </item>
    <item android:left="1dp" android:top="1dp" android:right="1dp">
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="270"
                android:startColor="#14FFFFFF"
                android:endColor="#00000000" />
            <corners android:radius="32dp" />
        </shape>
    </item>
</layer-list>
