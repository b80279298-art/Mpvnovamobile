<?xml version="1.0" encoding="utf-8"?>
<!--
    State selector for player TEXT buttons (speed, decoder, etc.). Shared
    between the player overlay's control bar and picker-dialog text controls.
    Both state_focused (dialog framework-focus path) and state_selected
    (player overlay's btnSelected model) need to light up the button.
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true"  android:drawable="@drawable/bg_tv_player_button_focused" />
    <item android:state_pressed="true"  android:drawable="@drawable/bg_tv_player_button_focused" />
    <item android:state_selected="true" android:drawable="@drawable/bg_tv_player_button_focused" />
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent" />
            <corners android:radius="14dp" />
        </shape>
    </item>
</selector>
