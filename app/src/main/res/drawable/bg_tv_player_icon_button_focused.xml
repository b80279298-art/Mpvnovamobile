<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="oval">
            <solid android:color="?attr/mpvFocusWashSoft" />
        </shape>
    </item>
    <item android:left="2dp" android:top="2dp" android:right="2dp" android:bottom="2dp">
        <shape android:shape="oval">
            <gradient
                android:angle="270"
                android:endColor="#7813171C"
                android:startColor="#9630353C"
                android:type="linear" />
            <stroke android:width="1dp" android:color="?attr/mpvStrokeFocus" />
        </shape>
    </item>
</layer-list>
