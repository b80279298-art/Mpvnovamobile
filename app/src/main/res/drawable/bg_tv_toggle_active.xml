<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <gradient
                android:angle="315"
                android:endColor="?attr/mpvAccentDeep"
                android:startColor="?attr/mpvAccent"
                android:type="linear" />
            <stroke android:width="1dp" android:color="?attr/mpvStrokeFocus" />
            <corners android:radius="18dp" />
        </shape>
    </item>

    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="?attr/mpvFocusWashSoft" />
            <corners android:radius="18dp" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="315"
                android:endColor="?attr/mpvAccentDeep"
                android:startColor="?attr/mpvAccent"
                android:type="linear" />
            <stroke android:width="1dp" android:color="?attr/mpvStrokeStrong" />
            <corners android:radius="18dp" />
        </shape>
    </item>
</selector>
