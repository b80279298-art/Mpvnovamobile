<?xml version="1.0" encoding="utf-8"?>
<!--
    State selector for player ICON buttons. This style is shared between the
    player overlay's control bar and the various picker dialogs' icon
    controls, so both state_focused (used by dialog dpad navigation) AND
    state_selected (used by the player overlay's btnSelected model) need to
    light up the button. They both resolve to the same highlighted drawable.
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="false">
        <shape android:shape="oval">
            <solid android:color="@android:color/transparent" />
        </shape>
    </item>
    <item android:state_focused="true" android:drawable="@drawable/bg_tv_player_icon_button_focused" />
    <item android:state_pressed="true" android:drawable="@drawable/bg_tv_player_icon_button_focused" />
    <item android:state_selected="true" android:drawable="@drawable/bg_tv_player_icon_button_focused" />
    <item>
        <shape android:shape="oval">
            <solid android:color="@android:color/transparent" />
        </shape>
    </item>
</selector>
